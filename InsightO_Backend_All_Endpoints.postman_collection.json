              "raw": "{\n  \"content\": \"Here is my submission.\",\n  \"attachments\": [\n    {\n      \"url\": \"https://example.com/submission.pdf\",\n      \"fileName\": \"submission.pdf\",\n      \"size\": 50000\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/task-submissions/task/{{taskId}}"
          }
        },
        {
          "name": "Get Task Submissions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/task-submissions/task/{{taskId}}"
          }
        },
        {
          "name": "Finalize Grade",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"final_grade\": 95,\n  \"instructor_feedback\": \"Excellent work!\"\n}"
            },
            "url": "{{baseUrl}}/api/task-submissions/{{submissionId}}/grade"
          }
        }
      ]
    }
  ]
}
