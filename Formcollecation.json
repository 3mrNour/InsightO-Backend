{
  "info": {
    "name": "insightO - Forms & Questions API",
    "_postman_id": "12345-forms-collection",
    "description": "Testing Forms & Questions APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": "YOUR_TOKEN_HERE"
    },
    {
      "key": "formId",
      "value": ""
    },
    {
      "key": "questionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Forms",
      "item": [
        {
          "name": "Create Form",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Instructor Evaluation\",\n  \"description\": \"Rate your instructor\",\n  \"evaluator_roles\": [\"STUDENT\"],\n  \"subject_role\": \"INSTRUCTOR\",\n  \"is_anonymous\": true\n}"
            },
            "url": "{{baseUrl}}/forms"
          }
        },
        {
          "name": "Get All Forms",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/forms"
          }
        },
        {
          "name": "Get Form By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/forms/{{formId}}"
          }
        },
        {
          "name": "Update Form Settings",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            },
            "url": "{{baseUrl}}/forms/{{formId}}/settings"
          }
        },
        {
          "name": "Delete Form",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/forms/{{formId}}"
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "Add Question",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Rate teaching quality\",\n  \"type\": \"linear_scale\",\n  \"order\": 1,\n  \"required\": true\n}"
            },
            "url": "{{baseUrl}}/forms/{{formId}}/questions"
          }
        },
        {
          "name": "Get Questions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/forms/{{formId}}/questions"
          }
        },
        {
          "name": "Update Question",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "application/json": "" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Updated question\"\n}"
            },
            "url": "{{baseUrl}}/forms/questions/{{questionId}}"
          }
        },
        {
          "name": "Delete Question",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/forms/questions/{{questionId}}"
          }
        },
        {
          "name": "Reorder Questions",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"id\": \"QUESTION_ID_1\", \"order\": 2 },\n  { \"id\": \"QUESTION_ID_2\", \"order\": 1 }\n]"
            },
            "url": "{{baseUrl}}/forms/{{formId}}/questions/reorder"
          }
        }
      ]
    }
  ]
}